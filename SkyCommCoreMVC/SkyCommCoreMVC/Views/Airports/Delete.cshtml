@model SkyCommCoreMVC.Models.Airports

@{
    ViewData["Title"] = "Airport Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3>Delete: @Model.AirportName</h3>
<h4>Are you sure you want to delete this?</h4>
<h4>
    NOTE: This form is for display only. The delete fuctionality is not implemented in this sample application.
</h4>
<hr />
<div>
    <dl class="row">
        <dt class="col-sm-3">
            @Html.Label("IATA Code")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.AirportIatacode)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Identifier")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.AirportIdentifier)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Name")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.AirportName)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Latitude (degrees)")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.AirportLatitudeDegrees)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Longitude (degrees)")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.AirportLongitudeDegrees)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Elevation (feet)")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.AirportElevationFeet)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Municipality")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.AirportMunicipality)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Scheduled Service")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.AirportScheduledService)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("GPS Code")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.AirportGpscode)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Local Code")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.AirportLocalCode)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Home URL")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.AirportHomeLink)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Wikipedia URL")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.AirportWikipediaLink)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Airport Type")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.AirportType.AirportType)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Region Code")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Region.RegionCode)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("SkyComm Ops Level")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.SkyCommOpsLevel.SkyCommOpsLevel)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="AirportId" />
        @*<input type="submit" value="Delete" class="btn btn-danger" /> |*@
        <a class="btn btn-outline-primary" href="@ViewBag.returnUrl">Back to Previous Page</a>
        <a class="btn btn-outline-primary" asp-action="Index">Return to Airports Home</a>
    </form>
</div>
