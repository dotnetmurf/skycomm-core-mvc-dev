@{
    ViewData["Title"] = "Home Page";
}

<div class="jumbotron">
    <h1>SkyComm</h1>
</div>
<section>
    <h2>Welcome to SkyComm</h2>
    <p>
        SkyComm is a sample application that
        demonstrates how to use Entity Framework Core in an
        ASP.NET Core MVC web application.
    </p>
</section>
<div class="row">
    <div class="col-md-4">
        <h2>Airports</h2>
        <p>The Airports section.</p>
        <p></p><a class="btn btn-default" asp-area="" asp-controller="Airports" asp-action="Index">Airports &raquo;</a></p>
    </div>
    <div class="col-md-4">
        <h2>Equipment</h2>
        <p>The Equipment section.</p>
        <p></p><a class="btn btn-default" asp-area="" asp-controller="Equipment" asp-action="Index">Equipment &raquo;</a></p>
    </div>
    <div class="col-md-4">
        <h2>Office</h2>
        <p>The Offices section.</p>
        <p></p><a class="btn btn-default" asp-area="" asp-controller="Offices" asp-action="Index">Offices &raquo;</a></p>
    </div>
</div>