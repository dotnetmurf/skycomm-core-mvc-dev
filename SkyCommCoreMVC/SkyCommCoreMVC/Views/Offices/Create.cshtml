@model SkyCommCoreMVC.Models.Offices

@{
    ViewData["Title"] = "Office Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3>Create a new Office</h3>
<h4>
    NOTE: This form is for display only. The create fuctionality is not implemented in this sample application.
</h4>
<hr />
<div class="row">
    <div class="col-md-9">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="OfficeName" class="control-label">Name</label>
                <input asp-for="OfficeName" class="form-control" />
                <span asp-validation-for="OfficeName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OfficeAddress1" class="control-label">Address 1</label>
                <input asp-for="OfficeAddress1" class="form-control" />
                <span asp-validation-for="OfficeAddress1" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OfficeAddress2" class="control-label">Address 2</label>
                <input asp-for="OfficeAddress2" class="form-control" />
                <span asp-validation-for="OfficeAddress2" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OfficeCity" class="control-label">City</label>
                <input asp-for="OfficeCity" class="form-control" />
                <span asp-validation-for="OfficeCity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OfficeState" class="control-label">State</label>
                <input asp-for="OfficeState" class="form-control" />
                <span asp-validation-for="OfficeState" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CountryId" class="control-label">Country</label>
                <select asp-for="CountryId" class="form-control" asp-items="ViewBag.CountryId"></select>
                <span asp-validation-for="CountryId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OfficePostalCode" class="control-label">Postal Code</label>
                <input asp-for="OfficePostalCode" class="form-control" />
                <span asp-validation-for="OfficePostalCode" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OfficePhoneNumber" class="control-label">Telephone Number</label>
                <input asp-for="OfficePhoneNumber" class="form-control" />
                <span asp-validation-for="OfficePhoneNumber" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OfficeFaxNumber" class="control-label">Fax Number</label>
                <input asp-for="OfficeFaxNumber" class="form-control" />
                <span asp-validation-for="OfficeFaxNumber" class="text-danger"></span>
            </div>
            <div class="form-group">
                @*<input type="submit" value="Create" class="btn btn-primary" />*@
            </div>
        </form>
    </div>
</div>

<div>
    <a class="btn btn-outline-primary" href="@ViewBag.returnUrl">Back to Previous Page</a>
    <a class="btn btn-outline-primary" asp-controller="Offices" asp-action="Search">Return to Offices Search</a>
    <a class="btn btn-outline-primary" asp-controller="Offices" asp-action="Filter">Return to Offices Filter</a>
    <a class="btn btn-outline-primary" asp-controller="Personnel" asp-action="Index">Return to Personnel Home</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
