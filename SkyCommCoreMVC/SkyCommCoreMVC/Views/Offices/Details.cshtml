@model SkyCommCoreMVC.Models.Offices

@{
    ViewData["Title"] = "Office Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3>Details: @Model.OfficeName</h3>
<hr />
<div>
    <dl class="row">
        <dt class="col-sm-3">
            @Html.Label("Address 1")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.OfficeAddress1)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Address 2")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.OfficeAddress2)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("City")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.OfficeCity)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("State")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.OfficeState)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Postal Code")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.OfficePostalCode)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Country")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Country.CountryName)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Telephone Number")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.OfficePhoneNumber)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Fax Number")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.OfficeFaxNumber)
        </dd>
    </dl>
</div>
<div>
    <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.OfficeId">Edit</a>
    <a class="btn btn-outline-primary" asp-action="Delete" asp-route-id="@Model.OfficeId">Delete</a>
    <a class="btn btn-outline-primary" href="@ViewBag.returnUrl">Back to Previous Page</a>
    <a class="btn btn-outline-primary" asp-controller="Offices" asp-action="Search">Return to Offices Search</a>
    <a class="btn btn-outline-primary" asp-controller="Offices" asp-action="Filter">Return to Offices Filter</a>
    <a class="btn btn-outline-primary" asp-controller="Personnel" asp-action="Index">Return to Personnel Home</a>
</div>
