@model IEnumerable<SkyCommCoreMVC.Models.Consoles>

@{
    ViewData["Title"] = "Consoles List";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<h3>Consoles List</h3>

<div class="row">
    @foreach (var item in Model)
    {
        var imagePath = @"/consoles/" + @item.Image;
        <div class="col-4">
            <div class="card border-secondary mb-3" style="max-width: 24rem;">
                <div class="card-header">@item.Title</div>
                <div class="card-body">
                    <img src="@imagePath" class="img-fluid" alt="@item.Title">
                    <p class="card-text">
                        @item.Title<br />
                        @item.Description<br />
                    </p>
                </div>
                <div class="card-footer">
                    <a href="#" class="btn btn-primary btn-sm" onclick="ShowConsole(@item.ConsoleId)">@item.ConsoleId</a>
                    @*<a href="#" class="btn btn-primary btn-sm" onclick="ShowConsole(@item.ConsoleId)">console</a>*@

                    @*<a class="btn btn-primary btn-sm" asp-area="" asp-controller="UnitModels" asp-action="Details" asp-route-id="@item.UnitModelId">Details &raquo;</a>*@
                </div>
            </div>
        </div>
    }
</div>

<div>
    <partial name="ConsolePartial" />
</div>

@*<div class="col-12">
    @await Component.InvokeAsync("Consoles", new { consoleID = 2.ToString() })

</div>*@

<!-- Modal -->
<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Modal title</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body col-12" id="exampleModalBodyDiv">
                <partial name="ConsolePartial" />
                @*@await Component.InvokeAsync("Consoles", new { consoleID = 2.ToString() })*@
                @*@await Component.InvokeAsync("Consoles", new { consoleID = selectedConsole })*@
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary">Save changes</button>
            </div>
        </div>
    </div>
</div>

<script>
    var selectedConsole;

    var ShowConsole = function (consoleID) {

        var url = "/Equipment/ShowConsolePartial?ConsoleID=" + consoleID;
        alert(url)
        $("#exampleModal").modal("show");

        //$("#exampleModalBodyDiv").load(url,function () {
        //    $("#exampleModal").modal("show");
        //})
    }

</script>
