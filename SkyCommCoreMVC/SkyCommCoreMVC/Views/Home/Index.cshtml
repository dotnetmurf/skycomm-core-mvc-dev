@{
    ViewData["Title"] = "Home Page";
}

<section class="home-index-section">
    <h2>Welcome to the SkyComm Resource Portal</h2>
    <p>
        The SkyComm Resource Portal is a corporate intranet web application for tracking resources
        and monitoring key performance indicators. More information about this application is
        available on the <a asp-area="" asp-controller="Home" asp-action="About">About</a> page.
    </p>
</section>

<div class="section-banner">
    <img src="~/images/logo/airports-banner.png" alt="Airports Section Logo" class="banner-logo" />
</div>
<section class="home-index-section">
    <h3>Airports</h3>
    <p>The Airports section contains the information relative to the airports.</p>
    <p></p><a class="btn btn-outline-primary" asp-area="" asp-controller="Airports" asp-action="Index">Go to the Airports section</a>
</section>

<div class="section-banner">
    <img src="~/images/logo/equipment-banner.png" alt="Equipment Section Logo" class="banner-logo" />
</div>
<section class="home-index-section">
    <h3>Equipment</h3>
    <p>
        The Equipment section contains the information relative to the equipment
        that comprises an airport communications system.
    </p>
    <p></p><a class="btn btn-outline-primary" asp-area="" asp-controller="Equipment" asp-action="Index">Go to the Equipment section</a>
</section>

<div class="section-banner">
    <img src="~/images/logo/personnel-banner.png" alt="Personnel Section Logo" class="banner-logo" />
</div>
<section class="home-index-section">
    <h3>Personnel</h3>
    <p>
        The Personnel section contains the information relative to the SkyComm
        offices and personnel that comprises its global operations.
    </p>
    <p></p><a class="btn btn-outline-primary" asp-area="" asp-controller="Personnel" asp-action="Index">Go to the Personnel section</a>
</section>

