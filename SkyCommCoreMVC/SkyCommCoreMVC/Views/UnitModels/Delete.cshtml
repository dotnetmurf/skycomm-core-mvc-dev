@model SkyCommCoreMVC.Models.UnitModels

@{
    ViewData["Title"] = "Model Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3>Delete: @Model.ModelName</h3>
<h4>Are you sure you want to delete this?</h4>
<h4>
    NOTE: This form is for display only. The delete fuctionality is not implemented in this sample application.
</h4>
<hr />
<div>
    <dl class="row">
        <dt class="col-sm-3">
            @Html.Label("Model Code")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.ModelCode)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Model Name")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.ModelName)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Model Image File")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.ModelImage)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("MSRP")
        </dt>
        <dd class="col-sm-9">
            @Model.ModelMsrp.ToString("c")
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Category")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.ModelCategory.ModelCategory)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Frequency Band")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.ModelFreqBand.ModelFreqBand)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Manufacturer")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.ModelManufacturer.ModelManufacturerName)
        </dd>
        <dt class="col-sm-3">
            @Html.Label("Modulation Type")
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.ModelModType.ModelModType)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="UnitModelId" />
        @*<input type="submit" value="Delete" class="btn btn-danger" /> |*@
        <a class="btn btn-outline-primary" href="@ViewBag.returnUrl">Back to Previous Page</a>
        <a class="btn btn-outline-primary" asp-controller="Equipment" asp-action="Index">Return to Equipment Home</a>
    </form>
</div>
